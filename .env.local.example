# Copia este archivo a .env.local y rellena con los valores de tu proyecto Supabase
# (Project Settings -> API en el dashboard de Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Solo en servidor (NUNCA con prefijo NEXT_PUBLIC). Se usará para firmar subidas
# grandes y operaciones administrativas en iteraciones posteriores.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta

# Groq (gratis): transcripción de audio para generar LRC automático.
# Crea una cuenta gratuita en https://console.groq.com y genera una API key.
GROQ_API_KEY=tu-groq-api-key
